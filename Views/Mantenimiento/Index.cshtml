@model IEnumerable<TalleresRMP.Models.Mantenimiento>
@{
    ViewData["Title"] = "Lista de Mantenimientos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="text-rmp mb-0">Lista de Mantenimientos</h1>
    <a class="btn btn-rmp" asp-action="Create">
        <i class="bi bi-plus"></i> Nuevo Mantenimiento
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No hay mantenimientos registrados.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="thead-rmp">
                <tr>
                    <th>N°</th>
                    <th>Número</th>
                    <th>Cliente</th>
                    <th>Placa</th>
                    <th>Estado</th>
                    <th>Fecha</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @{ var fila = 1; }
                @foreach (var m in Model)
                {
                    <tr>
                        <td>@(fila++)</td>
                        <td>@m.Numero</td>
                        <td>@m.Cliente</td>
                        <td>@m.Placa</td>
                        <td><span class="badge bg-secondary">@m.Estado</span></td>
                        <td>@m.FechaCreacion.ToString("dd/MM/yyyy")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-success" asp-action="Details" asp-route-id="@m.IdMantenimiento">Ver</a>
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@m.IdMantenimiento">Editar</a>
                            <form asp-action="Delete" asp-route-id="@m.IdMantenimiento" method="post" class="d-inline"
                                  onsubmit="return confirm('¿Eliminar el mantenimiento N° @m.Numero? Esta acción no se puede deshacer.');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
