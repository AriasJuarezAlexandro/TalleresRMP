@model IEnumerable<TalleresRMP.Models.Mantenimiento>
@{
    ViewData["Title"] = "Inicio";
}

<h1 class="text-rmp mb-4">Mantenimientos — Últimos registros</h1>

@if (!Model.Any())
{
    <div class="alert alert-info">No hay registros en el rango de fechas.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="thead-rmp">
                <tr>
                    <th>ID</th>
                    <th>Número</th>
                    <th>Cliente</th>
                    <th>Teléfono</th>
                    <th>Fecha</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model)
                {
                    <tr>
                        <td>@m.IdMantenimiento</td>
                        <td>@m.Numero</td>
                        <td>@m.Cliente</td>
                        <td>@m.Telefono</td>
                        <td>@m.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
